# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tekapakhi_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=change-this-to-a-secure-random-string #require('crypto').randomBytes(64).toString('hex') in node
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OTP Configuration
OTP_EXPIRY_MINUTES=5

# Security
MAX_PIN_ATTEMPTS=5
PIN_LOCK_DURATION_MINUTES=30
