# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tekapakhi_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=change-this-to-a-secure-random-string #require('crypto').randomBytes(64).toString('hex') in node
JWT_ACCESS_EXPIRY=15m
JWT_ADMIN_EXPIRY=8h

# Admin panel (/root) — bcrypt hash of password (salt rounds 12). Dev default password: dev-admin-password
ADMIN_PASSWORD_HASH=$2b$12$3tEI4bhI8ygdFK5aM2uoseNMePsPxF2JjVuoT7GAVnemIsK2mfbOe

# OTP Configuration
OTP_EXPIRY_MINUTES=5

# Security
MAX_PIN_ATTEMPTS=5
PIN_LOCK_DURATION_MINUTES=30
